# UTrack Environment Variables

# Firebase Configuration
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

# Cloud Functions Environment Variables (set via Firebase CLI)
# firebase functions:config:set sendgrid.api_key="your_sendgrid_api_key"
# firebase functions:config:set admin.email="your_admin_email@domain.com"
# firebase functions:config:set razorpay.webhook_secret="your_razorpay_webhook_secret"

# Razorpay Configuration (for client-side)
VITE_RAZORPAY_KEY_ID=rzp_test_your_key_id_here

# Google Gemini API (for bill processing)
API=your_google_gemini_api_key_here